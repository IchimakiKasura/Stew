{
    "$schema": "node_modules/wrangler/config-schema.json",

    "name": "localserver",
    "main": "worker/localworker.js",
    "compatibility_date": "2026-06-18",

    "assets": {
        "directory": "src/",
        "not_found_handling": "404-page",
        "run_worker_first": ["/submit"]
    },

    "observability": {
        "enabled": true
    },

    "dev": {
        "port": 5500
    }
}